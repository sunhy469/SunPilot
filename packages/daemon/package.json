{
  "name": "@sunpilot/daemon",
  "version": "0.1.0",
  "type": "module",
  "exports": {
    ".": "./dist/server.js",
    "./main": "./dist/main.js"
  },
  "bin": {
    "sunpilot-daemon": "./dist/main.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx src/main.ts --foreground",
    "start": "node dist/main.js --foreground",
    "test": "vitest run --passWithNoTests",
    "lint": "eslint ."
  },
  "dependencies": {
    "@fastify/cors": "^10.1.0",
    "@fastify/static": "^8.2.0",
    "@sunpilot/web": "workspace:*",
    "@sunpilot/core": "workspace:*",
    "@sunpilot/protocol": "workspace:*",
    "@sunpilot/skill-runner": "workspace:*",
    "@sunpilot/storage": "workspace:*",
    "@sunpilot/workflow": "workspace:*",
    "fastify": "^5.3.3",
    "pino": "^9.7.0",
    "ws": "^8.18.2",
    "zod": "^3.25.48"
  },
  "devDependencies": {
    "@types/ws": "^8.18.1",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3",
    "vitest": "^3.2.1"
  }
}
